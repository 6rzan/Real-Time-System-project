reports/runs/*.ndjson
reports/runs/*.log

# Criterion output (huge HTML; regenerable)
target/criterion/

# Plots that the report regenerates (kept in docs/research-report/figures/ instead)
reports/plots/*.png
reports/plots/*.pdf

# Non-essential local doc binaries (large reference material)
Rust_documentation*.docx

